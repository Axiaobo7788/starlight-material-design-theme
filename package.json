{
  "name": "starlight-theme-md3",
  "description": "A Material Design 3 / Material You inspired theme for Astro Starlight.",
  "type": "module",
  "version": "0.1.2",
  "packageManager": "pnpm@10.33.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aXiaobo7788/starlight-material-design-theme.git"
  },
  "bugs": {
    "url": "https://github.com/aXiaobo7788/starlight-material-design-theme/issues"
  },
  "homepage": "https://axiaobo7788.github.io/starlight-material-design-theme/",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./css/index.css": "./dist/css/index.css",
    "./css/*": "./dist/css/*"
  },
  "files": [
    "dist",
    "docs/README.zh-CN.md",
    "docs/readme",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "astro",
    "starlight",
    "theme",
    "material-design",
    "material-you",
    "docs"
  ],
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "pnpm run build:theme && pnpm run build:demo",
    "build:theme": "node scripts/clean-package.mjs && tsc -p tsconfig.package.json && node scripts/copy-css.mjs",
    "build:demo": "astro build",
    "check:contrast": "pnpm run build:theme && node scripts/check-contrast.mjs",
    "verify:package": "node scripts/verify-package-consumption.mjs",
    "test:screenshots": "playwright test --workers=1",
    "test:screenshots:update": "playwright test --update-snapshots --workers=1",
    "typecheck": "astro check",
    "preview": "astro preview",
    "astro": "astro"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.40.0",
    "astro": ">=6.4.5 <7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.40.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "astro": "^6.4.5",
    "lightningcss-cli": "^1.32.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@material/material-color-utilities": "0.4.0"
  }
}
